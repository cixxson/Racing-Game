<!DOCTYPE html>
<html>
<head>
<title>Fast Racing Game</title>
<style>
body{
margin:0;
background:#111;
overflow:hidden;
font-family:Arial;
}
#score{
position:absolute;
top:20px;
left:20px;
color:white;
font-size:24px;
}
#power{
position:absolute;
top:50px;
left:20px;
color:white;
font-size:18px;
}
#leaderboard{
position:absolute;
top:100px;
left:50%;
transform:translateX(-50%);
color:white;
font-size:18px;
text-align:center;
}
canvas{
display:block;
margin:auto;
background:#333;
}
</style>
</head>
<body>

<div id="score">Score: 0</div>
<div id="power"></div>
<div id="leaderboard"></div>
<canvas id="game"></canvas>

<script>
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
canvas.width = 400;
canvas.height = 600;

let keys = {};
let score = 0;
let baseScore = 1;
let gameOver = false;
let leaderboard = [];
let enemyFreezeTimer = 0; 

let normalScoreMultiplier = 1;
let carsPassedChain = 0;

let devCheatActive = false;
let cheatChainMultiplier = 1;
let scoreRain = [];

document.addEventListener("keydown", e => {
    keys[e.key] = true;

    if(e.key === "`"){
        devCheatActive = !devCheatActive;
        if(devCheatActive){
            nitroTimer = Infinity;
            invincibleTimer = Infinity;
            baseScore = 10000000; 
            player.speed = 8 * 100;
            cheatChainMultiplier = 1;
        } else {
            nitroTimer = 0;
            invincibleTimer = 0;
            baseScore = 1;
            player.speed = 8;
            enemyFreezeTimer = 90;
            cars = [];
        }
    }

    if(e.key === "="){
        devCheatActive = true;
        nitroTimer = Infinity;
        invincibleTimer = Infinity;
        baseScore = 10000000;
        player.speed = 8*100;
        cheatChainMultiplier = 1;
    }

    if(gameOver){
        resetGame();
    }
});

document.addEventListener("keyup", e => keys[e.key] = false);

const player = { x:180, y:480, width:40, height:80, speed:8 };
let cars = [];
let powerUps = [];
let roadOffset = 0;
let nitroTimer = 0;
let invincibleTimer = 0;

const POWERUP_DURATION = 180;

function resetGame(){
    score = 0;
    baseScore = devCheatActive ? 10000000 : 1;
    gameOver = false;
    cars = [];
    powerUps = [];
    nitroTimer = devCheatActive ? Infinity : 0;
    invincibleTimer = devCheatActive ? Infinity : 0;
    player.x = 180;
    player.y = 480;
    player.speed = devCheatActive ? 8*100 : 8;

    normalScoreMultiplier = 1;
    carsPassedChain = 0;

    cheatChainMultiplier = 1;
    scoreRain = [];
    document.getElementById("leaderboard").innerHTML = "";
    gameLoop();
}

function spawnCar(){
    const lanes = [20,100,180,260,340];
    cars.push({ x:lanes[Math.floor(Math.random()*lanes.length)], y:-120, width:40, height:80, speed:6+Math.random()*3 });
}

function spawnPowerUp(){
    const lanes = [20,100,180,260,340];
    const types = ["nitro","invincible"];
    powerUps.push({ x:lanes[Math.floor(Math.random()*lanes.length)], y:-100, size:30, type:types[Math.floor(Math.random()*types.length)], speed:6 });
}

function drawRoad(){
    ctx.fillStyle="#444";
    ctx.fillRect(0,0,400,600);
    ctx.strokeStyle="white";
    ctx.lineWidth=5;
    roadOffset += 10;
    for(let i=-40;i<600;i+=40){
        let y = i + roadOffset % 40;
        ctx.beginPath();
        ctx.moveTo(200,y);
        ctx.lineTo(200,y+20);
        ctx.stroke();
    }
}

function updatePlayer(){
    let currentSpeed = player.speed;

    if(nitroTimer>0){
        currentSpeed = devCheatActive?player.speed:14;
        scoreMultiplier=devCheatActive?10000000:2;
        if(!devCheatActive) nitroTimer--;
    }
    else{
        scoreMultiplier=devCheatActive?10000000:normalScoreMultiplier;
    }

    if(invincibleTimer>0 && !devCheatActive) invincibleTimer--;

    if(keys["ArrowLeft"]) player.x -= currentSpeed;
    if(keys["ArrowRight"]) player.x += currentSpeed;
    if(player.x<20) player.x=20;
    if(player.x>340) player.x=340;

    if(invincibleTimer>0||devCheatActive){
        ctx.shadowBlur=20;
        ctx.shadowColor="yellow";
    }

    ctx.fillStyle="cyan";
    ctx.fillRect(player.x,player.y,player.width,player.height);
    ctx.shadowBlur=0;
}

function updateCars(){
    ctx.fillStyle="red";

    cars.forEach((car,index)=>{

        car.y += car.speed;
        ctx.fillRect(car.x,car.y,car.width,car.height);

        if(player.x < car.x + car.width && player.x+player.width>car.x && player.y<car.y+car.height && player.y+player.height>car.y){
            if(!devCheatActive && invincibleTimer<=0) gameOver=true;
            if(devCheatActive){ 
                score += baseScore*cheatChainMultiplier;
                cheatChainMultiplier *= 2;
                createScoreRain(car.x, car.y, baseScore*cheatChainMultiplier);
            }
        }

        if(car.y>canvas.height){
            cars.splice(index,1);
            if(devCheatActive){ 
                score += baseScore*cheatChainMultiplier; 
                cheatChainMultiplier *= 2; 
                createScoreRain(car.x,car.y,baseScore*cheatChainMultiplier); 
            } else {

                score += normalScoreMultiplier * (nitroTimer>0 ? 2 : 1);

                carsPassedChain++;
                if(carsPassedChain % 5 === 0){
                    normalScoreMultiplier += 0.5;
                }
            }
        }
    });
}

function updatePowerUps(){
    powerUps.forEach((p,index)=>{
        p.y += p.speed;

        if(p.type==="nitro") ctx.fillStyle="yellow";
        if(p.type==="invincible") ctx.fillStyle="purple";

        ctx.beginPath();
        ctx.arc(p.x+15,p.y+15,p.size/2,0,Math.PI*2);
        ctx.fill();

        if(player.x < p.x + p.size && player.x+player.width>p.x && player.y < p.y+p.size && player.y+player.height>p.y){

            if(devCheatActive){
                if(p.type==="nitro"){ nitroTimer = Infinity; }
                if(p.type==="invincible"){ invincibleTimer = Infinity; }
                score += baseScore*1000;
                createScoreRain(p.x,p.y,baseScore*1000);
            } else {

                if(p.type==="nitro"){
                    nitroTimer = POWERUP_DURATION;
                }

                if(p.type==="invincible"){
                    invincibleTimer = POWERUP_DURATION;
                }

            }

            powerUps.splice(index,1);
        }

        if(p.y>canvas.height){ powerUps.splice(index,1); }
    });
}

function updateUI(){
    let text = "";
    if(nitroTimer>0) text+="⚡ Nitro ";
    if(invincibleTimer>0) text+="🛡 Invincible ";
    if(devCheatActive) text+=" 🏆 DEV CHEAT ACTIVE!";
    document.getElementById("power").textContent=text;
}

function showLeaderboard(){
    leaderboard.push(score);
    leaderboard.sort((a,b)=>b-a);
    let html="<h2>Leaderboard</h2>";
    leaderboard.forEach((s,i)=>{ html+=`${i+1}. ${s}<br>`; });
    document.getElementById("leaderboard").innerHTML=html;
}

function createScoreRain(x,y,val){
    scoreRain.push({x:x, y:y, value:val, alpha:1});
}

function drawScoreRain(){
    ctx.font="16px Arial";
    scoreRain.forEach((s,i)=>{
        ctx.fillStyle=`rgba(255,255,0,${s.alpha})`;
        ctx.fillText("+"+Math.floor(s.value), s.x, s.y);
        s.y -= 2;
        s.alpha -= 0.02;
        if(s.alpha<=0) scoreRain.splice(i,1);
    });
}

function gameLoop(){
    if(gameOver){
        ctx.fillStyle="black";
        ctx.fillRect(0,0,400,600);
        ctx.fillStyle="white";
        ctx.font="40px Arial";
        ctx.fillText("Game Over",100,300);
        ctx.font="20px Arial";
        ctx.fillText("Press any key to restart",90,340);
        showLeaderboard();
        return;
    }

    drawRoad();
    updatePlayer();
    updateCars();
    updatePowerUps();
    updateUI();
    drawScoreRain();

    document.getElementById("score").textContent="Score: "+score;

    if(enemyFreezeTimer>0){ enemyFreezeTimer--; } 
    else{
        let carSpawnRate = devCheatActive?0.03*100000:0.03;
        if(Math.random()<carSpawnRate) spawnCar();
    }

    let powerUpSpawnRate = 0.01;
    if(Math.random()<powerUpSpawnRate) spawnPowerUp();

    requestAnimationFrame(gameLoop);
}

gameLoop();
</script>
</body>
</html>
